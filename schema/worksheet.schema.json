{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ensinolibre.dev/schema/worksheet.schema.json",
  "title": "EnsinoLibre Worksheet (v2 — full activity catalogue)",
  "description": "A self-contained digital worksheet. v2 covers the full EnsinoLibre component catalogue; every type has a defined analog (print/Markdown) translation. See context/ in the EnsinoLibre repo.",
  "type": "object",
  "required": ["title", "subject", "audience", "language", "sections"],
  "additionalProperties": false,
  "properties": {
    "$schemaVersion": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "topic": { "type": "string" },
    "audience": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 2 },
    "estimatedMinutes": { "type": "integer", "minimum": 1 },
    "instructions": { "type": "string" },
    "sections": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/section" } }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["title", "activities"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "instructions": { "type": "string" },
        "activities": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/activity" } }
      }
    },
    "hint": { "type": "string", "description": "Optional nudge on a wrong attempt. Must never quote, name, or point directly at the answer or any option." },
    "nonEmpty": { "type": "string", "minLength": 1 },
    "mcqCore": {
      "type": "object",
      "required": ["question", "options", "answer"],
      "properties": {
        "question": { "$ref": "#/$defs/nonEmpty" },
        "options": { "type": "array", "minItems": 2, "maxItems": 6, "items": { "$ref": "#/$defs/nonEmpty" } },
        "answer": { "type": "integer", "minimum": 0 },
        "hint": { "$ref": "#/$defs/hint" },
        "explanation": { "type": "string" }
      }
    },
    "tfCore": {
      "type": "object",
      "required": ["statement", "answer"],
      "properties": {
        "statement": { "$ref": "#/$defs/nonEmpty" },
        "answer": { "type": "boolean" },
        "hint": { "$ref": "#/$defs/hint" },
        "explanation": { "type": "string" }
      }
    },
    "gapCore": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "pattern": "\\{\\{[^{}]+\\}\\}" },
        "hint": { "$ref": "#/$defs/hint" },
        "explanation": { "type": "string" }
      }
    },
    "pair": {
      "type": "object",
      "required": ["left", "right"],
      "additionalProperties": false,
      "properties": { "left": { "$ref": "#/$defs/nonEmpty" }, "right": { "$ref": "#/$defs/nonEmpty" } }
    },
    "matchCore": {
      "type": "object",
      "required": ["pairs"],
      "properties": {
        "prompt": { "type": "string" },
        "pairs": { "type": "array", "minItems": 2, "maxItems": 8, "items": { "$ref": "#/$defs/pair" } },
        "hint": { "$ref": "#/$defs/hint" },
        "explanation": { "type": "string" }
      }
    },
    "activity": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["mcq", "true-false", "gap-fill", "matching", "ordering", "open-response",
            "content", "course-presentation", "timeline", "dialogue", "grammar-forms", "tense-shift",
            "word-transform", "translation-compare", "flashdeck", "memory-game", "word-search",
            "dictation", "listen-mcq", "quiz", "single-choice-set", "question-set", "mark-words",
            "reading-comp", "translation", "scenario", "lesson", "crossword", "image-hotspot",
            "summary", "survey", "poll"]
        },
        "instruction": { "type": "string" }
      },
      "allOf": [
        { "if": { "properties": { "type": { "const": "mcq" } } }, "then": { "$ref": "#/$defs/mcqCore" } },
        { "if": { "properties": { "type": { "const": "true-false" } } }, "then": { "$ref": "#/$defs/tfCore" } },
        { "if": { "properties": { "type": { "const": "gap-fill" } } }, "then": { "$ref": "#/$defs/gapCore" } },
        { "if": { "properties": { "type": { "const": "matching" } } }, "then": { "allOf": [{ "$ref": "#/$defs/matchCore" }, { "required": ["prompt"] }] } },
        { "if": { "properties": { "type": { "const": "ordering" } } }, "then": {
          "required": ["prompt", "items"],
          "properties": {
            "prompt": { "$ref": "#/$defs/nonEmpty" },
            "items": { "type": "array", "minItems": 3, "maxItems": 8, "items": { "$ref": "#/$defs/nonEmpty" } }
          } } },
        { "if": { "properties": { "type": { "const": "open-response" } } }, "then": {
          "required": ["prompt"],
          "properties": {
            "prompt": { "$ref": "#/$defs/nonEmpty" },
            "minWords": { "type": "integer", "minimum": 1 },
            "sampleAnswer": { "type": "string" }
          } } },
        { "if": { "properties": { "type": { "const": "content" } } }, "then": {
          "required": ["sections"],
          "properties": {
            "sections": { "type": "array", "minItems": 1, "items": {
              "type": "object", "required": ["heading", "body"],
              "properties": { "heading": { "$ref": "#/$defs/nonEmpty" }, "body": { "$ref": "#/$defs/nonEmpty" } } } }
          } } },
        { "if": { "properties": { "type": { "const": "course-presentation" } } }, "then": {
          "required": ["slides"],
          "properties": {
            "slides": { "type": "array", "minItems": 2, "maxItems": 12, "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "body": { "type": "string" },
                "activity": {
                  "type": "object",
                  "required": ["subtype"],
                  "properties": { "subtype": { "enum": ["mcq", "true-false"] } },
                  "allOf": [
                    { "if": { "properties": { "subtype": { "const": "mcq" } } }, "then": { "$ref": "#/$defs/mcqCore" } },
                    { "if": { "properties": { "subtype": { "const": "true-false" } } }, "then": { "$ref": "#/$defs/tfCore" } }
                  ]
                }
              },
              "anyOf": [{ "required": ["title"] }, { "required": ["body"] }]
            } }
          } } },
        { "if": { "properties": { "type": { "const": "timeline" } } }, "then": {
          "required": ["items"],
          "properties": {
            "items": { "type": "array", "minItems": 3, "maxItems": 12, "items": {
              "type": "object", "required": ["date", "headline"],
              "properties": { "date": { "$ref": "#/$defs/nonEmpty" }, "headline": { "$ref": "#/$defs/nonEmpty" }, "text": { "type": "string" } } } }
          } } },
        { "if": { "properties": { "type": { "const": "dialogue" } } }, "then": {
          "required": ["speakerA", "speakerB", "lines"],
          "properties": {
            "context": { "type": "string" },
            "speakerA": { "$ref": "#/$defs/nonEmpty" },
            "speakerB": { "$ref": "#/$defs/nonEmpty" },
            "lines": { "type": "array", "minItems": 2, "maxItems": 16, "items": {
              "type": "object", "required": ["speaker", "text"],
              "properties": { "speaker": { "enum": ["a", "b"] }, "text": { "$ref": "#/$defs/nonEmpty" }, "gloss": { "type": "string" } } } }
          } } },
        { "if": { "properties": { "type": { "const": "grammar-forms" } } }, "then": {
          "required": ["grammar", "forms"],
          "properties": {
            "grammar": { "$ref": "#/$defs/nonEmpty" },
            "forms": { "type": "array", "minItems": 2, "maxItems": 6, "items": {
              "type": "object", "required": ["label", "sentence"],
              "properties": { "label": { "$ref": "#/$defs/nonEmpty" }, "sentence": { "$ref": "#/$defs/nonEmpty" }, "gloss": { "type": "string" } } } }
          } } },
        { "if": { "properties": { "type": { "const": "tense-shift" } } }, "then": {
          "required": ["verb", "tenses"],
          "properties": {
            "verb": { "$ref": "#/$defs/nonEmpty" },
            "context": { "type": "string" },
            "tenses": { "type": "array", "minItems": 2, "maxItems": 6, "items": {
              "type": "object", "required": ["label", "sentence"],
              "properties": { "label": { "$ref": "#/$defs/nonEmpty" }, "sentence": { "$ref": "#/$defs/nonEmpty" }, "gloss": { "type": "string" } } } }
          } } },
        { "if": { "properties": { "type": { "const": "word-transform" } } }, "then": {
          "required": ["baseWord", "steps"],
          "properties": {
            "baseWord": { "$ref": "#/$defs/nonEmpty" },
            "steps": { "type": "array", "minItems": 2, "maxItems": 8, "items": {
              "type": "object", "required": ["derived", "pos", "morphemes"],
              "properties": {
                "derived": { "$ref": "#/$defs/nonEmpty" },
                "pos": { "$ref": "#/$defs/nonEmpty" },
                "morphemes": { "type": "array", "minItems": 1, "items": {
                  "type": "object", "required": ["text", "role"],
                  "properties": { "text": { "$ref": "#/$defs/nonEmpty" }, "role": { "enum": ["prefix", "root", "suffix"] } } } },
                "gloss": { "type": "string" },
                "example": { "type": "string" }
              } } }
          } } },
        { "if": { "properties": { "type": { "const": "translation-compare" } } }, "then": {
          "required": ["pairs"],
          "properties": {
            "pairs": { "type": "array", "minItems": 1, "maxItems": 6, "items": {
              "type": "object", "required": ["sourceTokens", "targetTokens", "links"],
              "properties": {
                "headline": { "type": "string" },
                "sourceTokens": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/nonEmpty" } },
                "targetTokens": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/nonEmpty" } },
                "links": { "type": "array", "minItems": 1, "items": {
                  "type": "object", "required": ["s", "t"],
                  "properties": { "s": { "type": "integer", "minimum": 0 }, "t": { "type": "integer", "minimum": 0 }, "note": { "type": "string" } } } }
              } } }
          } } },
        { "if": { "properties": { "type": { "const": "flashdeck" } } }, "then": {
          "required": ["cards"],
          "properties": {
            "cards": { "type": "array", "minItems": 3, "maxItems": 20, "items": {
              "type": "object", "required": ["front", "back"],
              "properties": {
                "front": { "$ref": "#/$defs/nonEmpty" }, "back": { "$ref": "#/$defs/nonEmpty" },
                "pronunciation": { "type": "string" }, "example": { "type": "string" }, "emoji": { "type": "string" }
              } } }
          } } },
        { "if": { "properties": { "type": { "const": "memory-game" } } }, "then": {
          "required": ["pairs"],
          "properties": { "pairs": { "type": "array", "minItems": 3, "maxItems": 8, "items": { "$ref": "#/$defs/pair" } } } } },
        { "if": { "properties": { "type": { "const": "word-search" } } }, "then": {
          "required": ["words"],
          "properties": {
            "words": { "type": "array", "minItems": 4, "maxItems": 14, "items": { "type": "string", "pattern": "^\\p{L}+$" } },
            "gridSize": { "type": "integer", "minimum": 6, "maximum": 16 }
          } } },
        { "if": { "properties": { "type": { "const": "dictation" } } }, "then": {
          "required": ["items"],
          "properties": {
            "items": { "type": "array", "minItems": 1, "maxItems": 8, "items": {
              "type": "object", "required": ["text"],
              "properties": { "text": { "$ref": "#/$defs/nonEmpty" }, "hint": { "$ref": "#/$defs/hint" } } } }
          } } },
        { "if": { "properties": { "type": { "const": "listen-mcq" } } }, "then": {
          "required": ["transcript", "questions"],
          "properties": {
            "transcript": { "$ref": "#/$defs/nonEmpty" },
            "showTranscriptAfter": { "type": "boolean" },
            "questions": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "$ref": "#/$defs/mcqCore" } }
          } } },
        { "if": { "properties": { "type": { "const": "quiz" } } }, "then": {
          "required": ["questions"],
          "properties": {
            "questions": { "type": "array", "minItems": 2, "maxItems": 12, "items": { "$ref": "#/$defs/mcqCore" } },
            "passMark": { "type": "integer", "minimum": 1 }
          } } },
        { "if": { "properties": { "type": { "const": "single-choice-set" } } }, "then": {
          "required": ["questions"],
          "properties": { "questions": { "type": "array", "minItems": 3, "maxItems": 12, "items": { "$ref": "#/$defs/mcqCore" } } } } },
        { "if": { "properties": { "type": { "const": "question-set" } } }, "then": {
          "required": ["questions"],
          "properties": {
            "questions": { "type": "array", "minItems": 2, "maxItems": 12, "items": {
              "type": "object",
              "required": ["subtype"],
              "properties": { "subtype": { "enum": ["mcq", "true-false", "gap-fill"] } },
              "allOf": [
                { "if": { "properties": { "subtype": { "const": "mcq" } } }, "then": { "$ref": "#/$defs/mcqCore" } },
                { "if": { "properties": { "subtype": { "const": "true-false" } } }, "then": { "$ref": "#/$defs/tfCore" } },
                { "if": { "properties": { "subtype": { "const": "gap-fill" } } }, "then": { "$ref": "#/$defs/gapCore" } }
              ]
            } },
            "passMark": { "type": "integer", "minimum": 1 }
          } } },
        { "if": { "properties": { "type": { "const": "mark-words" } } }, "then": {
          "required": ["instruction", "text", "targets"],
          "properties": {
            "instruction": { "$ref": "#/$defs/nonEmpty" },
            "text": { "$ref": "#/$defs/nonEmpty" },
            "targets": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmpty" } }
          } } },
        { "if": { "properties": { "type": { "const": "reading-comp" } } }, "then": {
          "required": ["passage", "questions"],
          "properties": {
            "passage": { "$ref": "#/$defs/nonEmpty" },
            "questions": { "type": "array", "minItems": 1, "maxItems": 10, "items": {
              "type": "object",
              "required": ["type"],
              "properties": { "type": { "enum": ["mcq", "true-false", "gap-fill", "matching"] } },
              "allOf": [
                { "if": { "properties": { "type": { "const": "mcq" } } }, "then": { "$ref": "#/$defs/mcqCore" } },
                { "if": { "properties": { "type": { "const": "true-false" } } }, "then": { "$ref": "#/$defs/tfCore" } },
                { "if": { "properties": { "type": { "const": "gap-fill" } } }, "then": { "$ref": "#/$defs/gapCore" } },
                { "if": { "properties": { "type": { "const": "matching" } } }, "then": { "$ref": "#/$defs/matchCore" } }
              ]
            } }
          } } },
        { "if": { "properties": { "type": { "const": "translation" } } }, "then": {
          "required": ["sentences"],
          "properties": {
            "sentences": { "type": "array", "minItems": 1, "maxItems": 10, "items": {
              "type": "object", "required": ["source", "target"],
              "properties": {
                "source": { "$ref": "#/$defs/nonEmpty" }, "target": { "$ref": "#/$defs/nonEmpty" },
                "alternatives": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } },
                "hint": { "$ref": "#/$defs/hint" }
              } } }
          } } },
        { "if": { "properties": { "type": { "const": "scenario" } } }, "then": {
          "required": ["startNode", "nodes"],
          "properties": {
            "startNode": { "$ref": "#/$defs/nonEmpty" },
            "nodes": { "type": "array", "minItems": 2, "items": {
              "type": "object", "required": ["id", "speaker", "text"],
              "properties": {
                "id": { "$ref": "#/$defs/nonEmpty" },
                "speaker": { "$ref": "#/$defs/nonEmpty" },
                "text": { "$ref": "#/$defs/nonEmpty" },
                "feedback": { "type": "string" },
                "isEnd": { "type": "boolean" },
                "endMessage": { "type": "string" },
                "choices": { "type": "array", "minItems": 1, "items": {
                  "type": "object", "required": ["text", "nextNode"],
                  "properties": { "text": { "$ref": "#/$defs/nonEmpty" }, "nextNode": { "$ref": "#/$defs/nonEmpty" }, "isCorrect": { "type": "boolean" } } } }
              } } }
          } } },
        { "if": { "properties": { "type": { "const": "lesson" } } }, "then": {
          "required": ["startPage", "pages"],
          "properties": {
            "startPage": { "$ref": "#/$defs/nonEmpty" },
            "pages": { "type": "array", "minItems": 2, "items": {
              "type": "object", "required": ["id", "pageType"],
              "properties": {
                "id": { "$ref": "#/$defs/nonEmpty" },
                "pageType": { "enum": ["content", "question"] },
                "title": { "type": "string" },
                "body": { "type": "string" },
                "nextPage": { "type": ["string", "null"] },
                "question": { "type": "string" },
                "options": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } },
                "answer": { "type": "integer", "minimum": 0 },
                "explanation": { "type": "string" },
                "onCorrect": { "type": ["string", "null"] },
                "onWrong": { "type": ["string", "null"] }
              } } }
          } } },
        { "if": { "properties": { "type": { "const": "crossword" } } }, "then": {
          "required": ["clues"],
          "properties": {
            "clues": {
              "type": "object",
              "required": ["across", "down"],
              "properties": {
                "across": { "type": "array", "items": { "$ref": "#/$defs/crosswordClue" } },
                "down": { "type": "array", "items": { "$ref": "#/$defs/crosswordClue" } }
              }
            }
          } } },
        { "if": { "properties": { "type": { "const": "image-hotspot" } } }, "then": {
          "required": ["svg", "hotspots"],
          "properties": {
            "svg": { "type": "string", "pattern": "^\\s*<svg[\\s>]" },
            "mode": { "enum": ["label", "quiz"] },
            "hotspots": { "type": "array", "minItems": 2, "maxItems": 10, "items": {
              "type": "object", "required": ["label", "x", "y"],
              "properties": {
                "label": { "$ref": "#/$defs/nonEmpty" },
                "x": { "type": "number", "minimum": 0, "maximum": 100 },
                "y": { "type": "number", "minimum": 0, "maximum": 100 },
                "description": { "type": "string" }
              } } }
          } } },
        { "if": { "properties": { "type": { "const": "summary" } } }, "then": {
          "required": ["statements"],
          "properties": {
            "intro": { "type": "string" },
            "statements": { "type": "array", "minItems": 4, "maxItems": 12, "items": {
              "type": "object", "required": ["text", "correct"],
              "properties": { "text": { "$ref": "#/$defs/nonEmpty" }, "correct": { "type": "boolean" }, "explanation": { "type": "string" } } } }
          } } },
        { "if": { "properties": { "type": { "const": "survey" } } }, "then": {
          "required": ["items"],
          "properties": {
            "items": { "type": "array", "minItems": 1, "maxItems": 8, "items": {
              "type": "object", "required": ["question", "itemType"],
              "properties": {
                "question": { "$ref": "#/$defs/nonEmpty" },
                "itemType": { "enum": ["scale", "choice", "opentext"] },
                "scale": { "type": "integer", "minimum": 2, "maximum": 10 },
                "labels": { "type": "array", "items": { "type": "string" } },
                "options": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } }
              } } }
          } } },
        { "if": { "properties": { "type": { "const": "poll" } } }, "then": {
          "required": ["question", "options"],
          "properties": {
            "question": { "$ref": "#/$defs/nonEmpty" },
            "options": { "type": "array", "minItems": 2, "maxItems": 5, "items": {
              "type": "object", "required": ["text"],
              "properties": { "text": { "$ref": "#/$defs/nonEmpty" }, "followUp": { "type": "string" } } } }
          } } }
      ]
    },
    "crosswordClue": {
      "type": "object",
      "required": ["number", "clue", "answer", "row", "col"],
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "clue": { "$ref": "#/$defs/nonEmpty" },
        "answer": { "type": "string", "pattern": "^\\p{L}+$" },
        "row": { "type": "integer", "minimum": 0 },
        "col": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
